# Copia este archivo a .env y completa tus valores (nunca subas .env a Git).
# PowerShell: Copy-Item .env.example .env

# --- SQLite (Python es dueño de la BD) ---
# Ruta relativa al repo o absoluta. Por defecto: database/autocv.sqlite
DATABASE_URL=sqlite:///database/autocv.sqlite

# --- API puente Python (n8n → HTTP) ---
BRIDGE_API_HOST=127.0.0.1
BRIDGE_API_PORT=8765
# Opcional: si lo defines, n8n debe enviar header X-Bridge-Token con este valor
BRIDGE_API_TOKEN=

# --- Ollama (LLM local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- n8n (solo referencia; el servicio se levanta con docker compose) ---
N8N_BASE_URL=http://localhost:5678

# --- Credenciales portales (rellena cuando implementes scrapers) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD= 
